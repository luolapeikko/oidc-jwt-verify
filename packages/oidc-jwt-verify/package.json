{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "@luolapeikko/oidc-jwt-verify",
  "version": "0.0.1",
  "description": "Simple asymmetric JWT validation for OIDC tokens",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    "import": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "require": {
      "types": "./dist/index.d.cts",
      "default": "./dist/index.cjs"
    },
    "default": "./dist/index.mjs"
  },
  "scripts": {
    "build": "tsdown src/index.ts --format cjs,esm --dts --clean -c tsconfig.build.json",
    "validate": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "repository": "github:luolapeikko/oidc-jwt-verify",
  "homepage": "https://github.com/luolapeikko/oidc-jwt-verify#readme",
  "bugs": {
    "url": "https://github.com/luolapeikko/oidc-jwt-verify/issues"
  },
  "keywords": [
    "jwt",
    "oidc",
    "validation",
    "jsonwebtoken",
    "openid"
  ],
  "author": "mharj",
  "license": "MIT",
  "peerDependencies": {
    "@avanio/auth-header": ">= 0.0.1",
    "@avanio/expire-cache": "^0.6.7",
    "@avanio/logger-like": ">= 0.1.0",
    "@luolapeikko/cache-types": ">= 0.0.1",
    "@standard-schema/spec": "^1.1.0",
    "jsonwebtoken": "^9"
  }
}
